{
  "name": "broadway-copilot-functions",
  "version": "0.0.1",
  "private": true,
  "description": "Google Cloud Functions for Broadway Copilot",
  "main": "dist/index.js",
  "scripts": {
    "start": "functions-framework --source=dist --target=${FUNCTION_TARGET} --port=${PORT:-8080}",
    "build": "npm run prisma:generate && tsc",
    "prisma:generate": "prisma generate",
    "postinstall": "npm run prisma:generate",
    "prestart": "npm run build",
    "test:imageUpload": "npm run build && functions-framework --source=dist --target=imageUpload --port=8080",
    "test:storeMemories": "npm run build && functions-framework --source=dist --target=storeMemories --port=8081",
    "test:indexWardrobe": "npm run build && functions-framework --source=dist --target=indexWardrobe --port=8082",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\""
  },
  "dependencies": {
    "@google-cloud/functions-framework": "^4.0.0",
    "@google-cloud/storage": "^7.17.1",
    "@prisma/client": "^6.16.0",
    "dotenv": "^17.2.2",
    "node-fetch": "^3.3.2",
    "openai": "^5.20.1"
  },
  "devDependencies": {
    "@types/node": "^24.3.1",
    "@types/node-fetch": "^2.6.13",
    "@typescript-eslint/eslint-plugin": "^8.44.0",
    "@typescript-eslint/parser": "^8.44.0",
    "eslint": "^9.35.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "prettier": "^3.6.2",
    "prisma": "^6.16.0",
    "typescript": "^5.9.2"
  }
}
